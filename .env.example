# =============================================================================
# Food Agent Environment Variables
# 复制为 .env 并填入实际值（.env 已在 .gitignore 中）
# =============================================================================

# ---- LLM 后端 (必需) --------------------------------------------------------
# MiniMax M3 OpenAI 兼容 API
MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-Text-01

# ---- 应用配置 ---------------------------------------------------------------
FOOD_AGENT_ENV=development
FOOD_AGENT_LOG_LEVEL=INFO

# ---- 可选：MCP 真实 API（mock 模式不需要） -----------------------------------
# AMAP_API_KEY=your_amap_key_here       # 高德地图
# OPENWEATHER_API_KEY=your_key_here     # 备用天气源
